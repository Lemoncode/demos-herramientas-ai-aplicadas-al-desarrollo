PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Compaction: none | sliding | summarize
COMPACTION=none

# Permission policy: always-ask | always-allow | allow-list
PERMISSION_POLICY=always-ask
# Comma-separated tool names to auto-approve (when PERMISSION_POLICY=allow-list)
ALLOW_LIST_TOOLS=read_file

# MCP server command (optional, space-separated args)
# Example: MCP_SERVER_CMD=npx -y @modelcontextprotocol/server-filesystem /tmp
MCP_SERVER_CMD=

# Enable diff approval before writing files: true | false
DIFF_APPROVAL=true

# Memory file path (default: .agent-memory.md in cwd)
MEMORY_FILE=.agent-memory.md
