PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Compaction: none | sliding | summarize
COMPACTION=none

# Permission policy: always-ask | always-allow | allow-list
PERMISSION_POLICY=always-ask
# Comma-separated tool names to auto-approve (when PERMISSION_POLICY=allow-list)
ALLOW_LIST_TOOLS=read_file
