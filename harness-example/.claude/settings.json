{
  "permissions": {
    "allow": [
      "Agent",
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/commit-guard.sh"
          }
        ]
      }
    ]
  }
}